	  <polyline points="270,778 270,650 930,650 930,332" fill="none" stroke="#eab308" stroke-width="1.8" marker-start="url(#mc)"/>
	  <polyline points="270,804 270,660 950,660 950,354" fill="none" stroke="#eab308" stroke-width="1.8" marker-end="url(#mc)"/>

	  <!-- Audio: PAM8302 IN+ ← GPIO48 -->
	  <polyline points="885,796 885,610 970,610 970,560" fill="none" stroke="#ec4899" stroke-width="1.8" marker-start="url(#me)"/>

	  <!-- DS18B20 DQ → GPIO8 -->
	  <polyline points="610,926 610,660 990,660 990,480" fill="none" stroke="#0891b2" stroke-width="1.8" marker-end="url(#md)"/>

	  <!-- WS2812 DIN ← GPIO38 -->
	  <polyline points="885,948 885,640 1000,640 1000,582" fill="none" stroke="#db2777" stroke-width="1.8" marker-start="url(#me)"/>

	  <!-- Power distribution: CH3 5V bus downward -->
	  <line x1="910" y1="240" x2="910" y2="690" stroke="#dc2626" stroke-width="2" stroke-dasharray="8 4"/>
	  <polyline points="600,748 600,700 910,700" fill="none" stroke="#dc2626" stroke-width="1.5"/>
	  <polyline points="850,748 850,705 910,705" fill="none" stroke="#dc2626" stroke-width="1.5"/>
	  <polyline points="885,948 885,710 910,710" fill="none" stroke="#dc2626" stroke-width="1.3"/>

	  <!-- 3.3V → DS18B20 VDD -->
	  <polyline points="610,926 610,670 1165,670 1165,240" fill="none" stroke="#7c3aed" stroke-width="1.3" stroke-dasharray="5 3"/>

	  <!-- CH2 12V → Motor -->
	  <line x1="665" y1="280" x2="665" y2="600" stroke="#eab308" stroke-width="2.5" stroke-dasharray="10 5"/>
	  <polyline points="120,750 120,610 665,610" fill="none" stroke="#eab308" stroke-width="2"/>

	  <!-- GND bus -->
	  <line x1="40" y1="1140" x2="1520" y2="1140" stroke="#94a3b8" stroke-width="3"/>
	  <text x="800" y="1160" text-anchor="middle" font-size="11" fill="#94a3b8" font-weight="700">GND 共地总线 — 所有模块 GND 引脚最终汇接到 DPC3512 电源 GND 端子</text>

	  <!-- Legend -->
	  <rect x="40" y="1040" width="700" height="80" rx="8" fill="white" stroke="#cbd5e1" stroke-width="1"/>
	  <text x="60" y="1064" font-size="12" font-weight="700" fill="#0f172a">图例 / Legend</text>
	  <g font-size="10">
	    <line x1="60" y1="1084" x2="100" y2="1084" stroke="#2563eb" stroke-width="2"/><text x="108" y="1088" fill="#475569">LCD/显示信号</text>
	    <line x1="220" y1="1084" x2="260" y2="1084" stroke="#eab308" stroke-width="2"/><text x="268" y="1088" fill="#475569">电机控制</text>
	    <line x1="380" y1="1084" x2="420" y2="1084" stroke="#16a34a" stroke-width="2"/><text x="428" y="1088" fill="#475569">传感器UART</text>
	    <line x1="540" y1="1084" x2="580" y2="1084" stroke="#ec4899" stroke-width="2"/><text x="588" y="1088" fill="#475569">音频+LED</text>
	    <line x1="60" y1="1108" x2="100" y2="1108" stroke="#dc2626" stroke-width="2" stroke-dasharray="6 3"/><text x="108" y="1112" fill="#475569">电源线 (实线=VCC, 虚线=信号供电)</text>
	    <line x1="380" y1="1108" x2="420" y2="1108" stroke="#94a3b8" stroke-width="2"/><text x="428" y="1112" fill="#475569">GND共地</text>
	  </g>

	  <!-- Checklist -->
	  <rect x="760" y="1040" width="720" height="80" rx="8" fill="#fffbeb" stroke="#f59e0b" stroke-width="1"/>
	  <text x="780" y="1064" font-size="12" font-weight="700" fill="#b45309">上电前检查清单</text>
