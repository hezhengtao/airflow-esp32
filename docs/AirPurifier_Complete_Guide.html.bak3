<tbody>
<tr><td>1</td><td>ESP32-S3 开发板</td><td>ESP32-S3 N16R8 + 扩展底座 (16MB Flash, 8MB PSRAM)</td><td>1</td><td>核心控制器</td><td>55</td><td>淘宝/立创</td></tr>
<tr><td>2</td><td>TFT 触摸屏</td><td>TK043F1509 (4.3" 480×800 IPS, NT35510+FT5x06)</td><td>1</td><td>人机界面</td><td>85</td><td>好钜润科技</td></tr>
