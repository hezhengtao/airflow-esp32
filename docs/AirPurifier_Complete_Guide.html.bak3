    <marker id="pd" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#7c3aed"/></marker>
  </defs>

  <rect width="1200" height="620" fill="#f8fafc"/>

  <!-- AC Input -->
  <rect x="440" y="20" width="320" height="70" rx="12" fill="white" stroke="#475569" stroke-width="2"/>
  <text x="600" y="50" text-anchor="middle" font-size="14" font-weight="700" fill="#0f172a">AC 220V 市电输入</text>
  <text x="600" y="74" text-anchor="middle" font-size="11" fill="#64748b">船型开关 (串联L火线) → DPC3512 输入端</text>

  <!-- DPC3512 -->
  <rect x="340" y="130" width="520" height="110" rx="14" fill="white" stroke="#475569" stroke-width="2.5" filter="url(#sh2)"/>
  <text x="600" y="160" text-anchor="middle" font-size="16" font-weight="700" fill="#0f172a">DPC3512 四路开关电源</text>
  <text x="600" y="182" text-anchor="middle" font-size="11" fill="#64748b">AC 220V → 4路独立DC输出 (隔离型, 共地输出端)</text>

  <!-- AC line -->
  <line x1="600" y1="90" x2="600" y2="130" stroke="#475569" stroke-width="2.5" marker-end="url(#pa)"/>

  <!-- Output rails -->
  <g font-size="11">
    <!-- CH1: 5V/3A -->
    <rect x="80" y="300" width="220" height="120" rx="10" fill="white" stroke="#dc2626" stroke-width="2" filter="url(#sh)"/>
    <text x="190" y="328" text-anchor="middle" font-size="13" font-weight="700" fill="#dc2626">CH1: 5V / 3A</text>
    <text x="190" y="350" text-anchor="middle" font-size="10" fill="#64748b">ESP32 USB-C 5V供电</text>
    <line x1="190" y1="362" x2="190" y2="400" stroke="#dc2626" stroke-width="2"/>
    <rect x="120" y="400" width="140" height="20" rx="5" fill="#fef2f2" stroke="#dc2626"/>
    <text x="190" y="415" text-anchor="middle" font-size="10" fill="#dc2626" font-weight="700">ESP32-S3 (板载LDO→3.3V)</text>

    <!-- CH2: 12V/2A -->
    <rect x="340" y="300" width="220" height="120" rx="10" fill="white" stroke="#eab308" stroke-width="2" filter="url(#sh)"/>
    <text x="450" y="328" text-anchor="middle" font-size="13" font-weight="700" fill="#ca8a04">CH2: 12V / 2A</text>
    <text x="450" y="350" text-anchor="middle" font-size="10" fill="#64748b">48F704P840 电机专用</text>
    <line x1="450" y1="362" x2="450" y2="400" stroke="#eab308" stroke-width="2"/>
    <rect x="380" y="400" width="140" height="20" rx="5" fill="#fefce8" stroke="#eab308"/>
    <text x="450" y="415" text-anchor="middle" font-size="10" fill="#ca8a04" font-weight="700">48F704P840 电机</text>

    <!-- CH3: 5V/2A -->
    <rect x="600" y="300" width="220" height="120" rx="10" fill="white" stroke="#16a34a" stroke-width="2" filter="url(#sh)"/>
    <text x="710" y="328" text-anchor="middle" font-size="13" font-weight="700" fill="#166534">CH3: 5V / 2A</text>
    <text x="710" y="350" text-anchor="middle" font-size="10" fill="#64748b">LCD + Y01 + PAM8302</text>
    <line x1="710" y1="362" x2="710" y2="400" stroke="#16a34a" stroke-width="2"/>
    <rect x="625" y="400" width="170" height="20" rx="5" fill="#f0fdf4" stroke="#16a34a"/>
