<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AiRFLOW 智能空气净化器 — 完整接线指南 & 物料清单</title>
<style>
  :root {
    --bg: #f1f5f9;
    --card: #ffffff;
    --card2: #f8fafc;
    --border: #e2e8f0;
    --text: #0f172a;
    --text2: #475569;
    --text3: #64748b;
    --pri: #4f46e5;
    --acc: #0ea5e9;
    --ok: #10b981;
    --warn: #f59e0b;
    --err: #ef4444;
    --lcd: #2563eb;
    --touch: #ea580c;
    --motor: #ca8a04;
    --sensor: #16a34a;
    --pwr: #7c3aed;
    --spk: #db2777;
    --r: 16px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: -apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',sans-serif; background:var(--bg); color:var(--text); line-height:1.8; padding:0; }
  .container { max-width:1500px; margin:0 auto; padding:32px 20px; }

  h1 { font-size:2.2em; text-align:center; background:linear-gradient(135deg,#0f172a,#3b82f6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; margin-bottom:4px; }
  h1 .sub { display:block; font-size:.38em; -webkit-text-fill-color:var(--text3); margin-top:4px; font-weight:400; }
  h2 { font-size:1.4em; color:#0f172a; margin:48px 0 16px; padding-bottom:8px; border-bottom:2px solid var(--border); border-left:5px solid var(--lcd); padding-left:14px; }
  h3 { font-size:1.1em; color:var(--text); margin:28px 0 12px; }

  .card { background:var(--card); border:1px solid var(--border); border-radius:var(--r); padding:24px 28px; margin:18px 0; box-shadow:0 2px 8px rgba(0,0,0,.04); }
  .card.hl { border-color:var(--pri); }

  .tbl-wrap { overflow-x:auto; margin:12px 0; }
  table { width:100%; border-collapse:collapse; font-size:.9em; }
  th, td { padding:10px 14px; text-align:left; border-bottom:1px solid var(--border); }
  th { background:var(--card2); color:var(--pri); font-weight:600; white-space:nowrap; }
  tr:hover td { background:rgba(0,0,0,.02); }
  .total-row td { font-weight:700; border-top:2px solid var(--pri); background:rgba(79,70,229,.04); }

  .gpio-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(155px,1fr)); gap:6px; }
  .gpio { background:var(--card2); border:1px solid var(--border); border-radius:6px; padding:10px 14px; transition:.15s; }
  .gpio:hover { transform:translateY(-1px); border-color:var(--text3); }
  .gpio .n { font-weight:700; font-size:1.05em; }
  .gpio .f { font-size:.85em; color:var(--text2); }
  .gpio .d { font-size:.75em; color:var(--text3); }
  .gpio.lcd { border-left:3px solid var(--lcd); }
  .gpio.touch { border-left:3px solid var(--touch); }
  .gpio.motor { border-left:3px solid var(--motor); }
  .gpio.sensor { border-left:3px solid var(--sensor); }
  .gpio.peri { border-left:3px solid var(--text3); }
  .gpio.spk { border-left:3px solid var(--spk); }
  .gpio.pwr { border-left:3px solid var(--pwr); }
  .gpio.reserved { opacity:.45; }
  .gpio .n.lcd { color:var(--lcd); }
  .gpio .n.touch { color:var(--touch); }
  .gpio .n.motor { color:var(--motor); }
  .gpio .n.sensor { color:var(--sensor); }
  .gpio .n.spk { color:var(--spk); }
  .gpio .n.pwr { color:var(--pwr); }

  .wire-box { background:var(--card); border:1px solid var(--border); border-radius:var(--r); padding:16px; margin:16px 0; overflow-x:auto; }

  .callout { border-left:4px solid var(--warn); padding:14px 18px; margin:14px 0; background:#fffbeb; border-radius:0 var(--r) var(--r) 0; }
  .callout.danger { border-color:var(--err); background:#fef2f2; }
  .callout.info { border-color:var(--acc); background:#f0f9ff; }
  .callout strong { display:block; margin-bottom:4px; color:var(--text); }

  .chk { list-style:none; columns:2; column-gap:24px; }
  .chk li { padding:5px 0; break-inside:avoid; }
  .chk li::before { content:"☐ "; color:var(--text3); }

  .flow { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; align-items:center; margin:20px 0; }
  .flow .node { background:var(--card2); border:1px solid var(--border); border-radius:var(--r); padding:18px 20px; text-align:center; min-width:130px; }
  .flow .node .lbl { font-weight:700; color:var(--pri); }
  .flow .node .det { font-size:.8em; color:var(--text3); margin-top:4px; }
  .flow .arr { font-size:1.4em; color:var(--warn); }

  .pwr-svg { max-width:100%; height:auto; }

  .steps { display:flex; flex-direction:column; gap:8px; }
  .step { display:flex; align-items:flex-start; gap:16px; padding:12px 16px; background:var(--card2); border-radius:var(--r); border:1px solid var(--border); }
  .step .num { background:var(--pri); color:white; border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center; font-weight:700; flex-shrink:0; }
  .step .info { flex:1; }
  .step .info strong { display:block; }
  .step .info span { font-size:.85em; color:var(--text2); }

  .legend { display:flex; flex-wrap:wrap; gap:16px; margin:12px 0; }
  .legend .dot { display:flex; align-items:center; gap:6px; font-size:.85em; }
  .legend .dot::before { content:''; width:12px; height:12px; border-radius:3px; }
  .legend .dot.lcd::before { background:var(--lcd); }
  .legend .dot.touch::before { background:var(--touch); }
  .legend .dot.motor::before { background:var(--motor); }
  .legend .dot.sensor::before { background:var(--sensor); }
  .legend .dot.pwr::before { background:var(--pwr); }
  .legend .dot.spk::before { background:var(--spk); }

  .wiring-svg text { font-family:'Segoe UI','PingFang SC',sans-serif; }

  .cmp-label { font-size:11px; fill:var(--text2); }
  .cmp-value { font-size:10px; fill:var(--text3); }

  @media (max-width:768px) {
    .container { padding:12px 8px; }
    h1 { font-size:1.4em; }
    .chk { columns:1; }
    .gpio-grid { grid-template-columns:repeat(auto-fill, minmax(120px,1fr)); }
  }
  @media print {
    body { background:white; color:black; }
    .card { box-shadow:none; border:1px solid #ccc; }
    .wire-box { background:white; border:1px solid #ccc; }
    .gpio { background:#fff; }
  }
</style>
</head>
<body>
<div class="container">

<h1>AiRFLOW 智能空气净化器
  <span class="sub">完整接线指南 &amp; 物料清单 · ESP32-S3 + TK043F1509 · v2.5 · 2026-05-30</span>
</h1>

<div style="text-align:center; margin:24px 0;">
  <img src="data:image/png;base64," alt="AiRFLOW Logo" style="max-width:200px; border-radius:12px;">
</div>

<!-- ═══════════════════════════════════════════════════════════ -->
