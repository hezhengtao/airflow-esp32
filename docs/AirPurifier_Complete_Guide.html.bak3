<h2>总装接线图 — PCB风格布局</h2>

<div class="svg-container">
<svg class="wiring-svg" viewBox="0 0 1600 1200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="ma" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#2563eb"/></marker>
    <marker id="mb" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#16a34a"/></marker>
    <marker id="mc" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#eab308"/></marker>
    <marker id="md" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#f97316"/></marker>
    <marker id="me" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#ec4899"/></marker>
    <marker id="mf" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#7c3aed"/></marker>
    <marker id="mg" markerWidth="10" markerHeight="8" refX="10" refY="4" orient="auto"><polygon points="0 0, 10 4, 0 8" fill="#dc2626"/></marker>
    <filter id="sh"><feDropShadow dx="1" dy="2" stdDeviation="3" flood-opacity="0.08"/></filter>
    <filter id="sh2"><feDropShadow dx="1" dy="4" stdDeviation="4" flood-opacity="0.12"/></filter>
  </defs>

  <rect width="1600" height="1200" fill="#f8fafc"/>

  <!-- === TITLE === -->
  <text x="800" y="34" text-anchor="middle" font-size="22" font-weight="700" fill="#0f172a">总装接线图 — AiRFLOW 智能空气净化器（PCB风格布局）</text>
  <text x="800" y="58" text-anchor="middle" font-size="12" fill="#64748b">全部杜邦线直连 · 横平竖直走线 · 所有GND共地 │ ESP32-S3 扩展底座</text>

  <!-- ======================================================================== -->
  <!-- POWER SUPPLY — horizontal bar at top -->
  <!-- ======================================================================== -->
  <rect x="280" y="80" width="1040" height="90" rx="12" fill="white" stroke="#7c3aed" stroke-width="2.5" filter="url(#sh2)"/>
  <text x="800" y="108" text-anchor="middle" font-size="14" font-weight="700" fill="#1e293b">DPC3512 四路开关电源 (AC 220V → 船型开关(串L火线) → 4路DC输出)</text>

  <!-- CH1 -->
  <rect x="310" y="122" width="220" height="36" rx="6" fill="#faf5ff" stroke="#a855f7" stroke-width="1.5"/>
  <text x="420" y="140" text-anchor="middle" font-size="12" font-weight="700" fill="#7c3aed">CH1: 5V / 3A</text>
  <text x="420" y="155" text-anchor="middle" font-size="9" fill="#64748b">ESP32 USB-C 供电</text>

  <!-- CH2 -->
  <rect x="555" width="220" y="122" height="36" rx="6" fill="#fefce8" stroke="#eab308" stroke-width="2"/>
  <text x="665" y="140" text-anchor="middle" font-size="12" font-weight="700" fill="#ca8a04">CH2: 12V / 2A</text>
  <text x="665" y="155" text-anchor="middle" font-size="9" fill="#64748b">48F704P840 电机专用</text>

  <!-- CH3 -->
  <rect x="800" y="122" width="220" height="36" rx="6" fill="#f0fdf4" stroke="#16a34a" stroke-width="1.5"/>
  <text x="910" y="140" text-anchor="middle" font-size="12" font-weight="700" fill="#166534">CH3: 5V / 2A</text>
  <text x="910" y="155" text-anchor="middle" font-size="9" fill="#64748b">LCD + Y01 + PAM8302</text>

  <!-- CH4 -->
  <rect x="1045" y="122" width="240" height="36" rx="6" fill="#fef2f2" stroke="#ef4444" stroke-width="1.5"/>
  <text x="1165" y="140" text-anchor="middle" font-size="12" font-weight="700" fill="#dc2626">CH4: 3.3V / 1A</text>
  <text x="1165" y="155" text-anchor="middle" font-size="9" fill="#dc2626"></text>

  <!-- Power vertical output buses -->
  <line x1="420" y1="170" x2="420" y2="210" stroke="#7c3aed" stroke-width="2" stroke-dasharray="6 3"/>
  <line x1="665" y1="170" x2="665" y2="280" stroke="#eab308" stroke-width="2" stroke-dasharray="6 3"/>
  <line x1="910" y1="170" x2="910" y2="240" stroke="#16a34a" stroke-width="2" stroke-dasharray="6 3"/>
  <line x1="1165" y1="170" x2="1165" y2="240" stroke="#dc2626" stroke-width="2" stroke-dasharray="6 3"/>

  <!-- ======================================================================== -->
  <!-- ESP32-S3 CENTER BLOCK -->
  <!-- ======================================================================== -->
  <rect x="80" y="200" width="1440" height="440" rx="16" fill="white" stroke="#6366f1" stroke-width="3" filter="url(#sh2)"/>

  <!-- ESP32 header -->
  <rect x="80" y="200" width="1440" height="44" rx="16" fill="#4f46e5"/>
  <rect x="80" y="228" width="1440" height="16" fill="#4f46e5"/>
  <text x="800" y="228" text-anchor="middle" font-size="15" font-weight="700" fill="white">ESP32-S3 N16R8 · WROOM-1 · 16MB Flash · 8MB PSRAM · 扩展底座引出全部GPIO · 所有GND共地</text>

  <!-- ── LEFT COLUMN: LCD pins ── -->
  <rect x="100" y="260" width="620" height="24" rx="4" fill="#eff6ff"/>
  <text x="410" y="277" text-anchor="middle" font-size="12" font-weight="700" fill="#2563eb">LCD 并行数据 + 控制 (8-bit 8080)</text>

  <g font-size="11">
    <!-- Data bus -->
    <text x="115" y="310" font-weight="700" fill="#2563eb">GPIO4</text>  <text x="210" y="310" fill="#475569">→ D0</text>
    <text x="270" y="310" font-weight="700" fill="#2563eb">GPIO5</text>  <text x="365" y="310" fill="#475569">→ D1</text>
    <text x="420" y="310" font-weight="700" fill="#2563eb">GPIO6</text>  <text x="515" y="310" fill="#475569">→ D2</text>
    <text x="570" y="310" font-weight="700" fill="#2563eb">GPIO7</text>  <text x="665" y="310" fill="#475569">→ D3</text>

    <text x="115" y="332" font-weight="700" fill="#2563eb">GPIO15</text> <text x="210" y="332" fill="#475569">→ D4</text>
    <text x="270" y="332" font-weight="700" fill="#2563eb">GPIO16</text> <text x="365" y="332" fill="#475569">→ D5</text>
    <text x="420" y="332" font-weight="700" fill="#2563eb">GPIO17</text> <text x="515" y="332" fill="#475569">→ D6</text>
    <text x="570" y="332" font-weight="700" fill="#2563eb">GPIO18</text> <text x="665" y="332" fill="#475569">→ D7</text>

    <!-- Control -->
    <text x="115" y="362" font-weight="700" fill="#2563eb">GPIO1</text>  <text x="210" y="362" fill="#475569">→ CS</text>
    <text x="270" y="362" font-weight="700" fill="#2563eb">GPIO42</text> <text x="365" y="362" fill="#475569">→ RS (D/C)</text>
    <text x="420" y="362" font-weight="700" fill="#2563eb">GPIO2</text>  <text x="515" y="362" fill="#475569">→ WR (PCLK)</text>
    <text x="570" y="362" font-weight="700" fill="#2563eb">GPIO46</text> <text x="665" y="362" fill="#475569">→ RST</text>
    <text x="115" y="384" font-weight="700" fill="#2563eb">GPIO19</text> <text x="210" y="384" fill="#475569">→ BL (背光 PWM 50kHz)</text>
  </g>

  <!-- ── LEFT COLUMN: Touch I2C ── -->
  <rect x="100" y="408" width="620" height="24" rx="4" fill="#fff7ed"/>
  <text x="410" y="425" text-anchor="middle" font-size="12" font-weight="700" fill="#f97316">Touch I2C (FT5x06, 地址 0x38) + 中断</text>

  <g font-size="11">
    <text x="115" y="458" font-weight="700" fill="#f97316">GPIO20</text>    <text x="210" y="458" fill="#475569">↔ SDA [R 4.7kΩ ↑3.3V]</text>
    <text x="380" y="458" font-weight="700" fill="#f97316">GPIO13</text>    <text x="475" y="458" fill="#475569">→ SCL [R 4.7kΩ ↑3.3V]</text>
    <text x="115" y="482" font-weight="700" fill="#475569">GPIO_NC</text>  <text x="210" y="482" fill="#64748b">← INT (未接)</text>
    <text x="380" y="482" font-weight="700" fill="#475569">GPIO_NC</text>  <text x="475" y="482" fill="#64748b">→ RST (未接)</text>
  </g>

  <!-- ── RIGHT COLUMN: Motor ── -->
  <rect x="780" y="260" width="600" height="24" rx="4" fill="#fefce8"/>
  <text x="1080" y="277" text-anchor="middle" font-size="12" font-weight="700" fill="#eab308">电机控制</text>

  <g font-size="11">
    <text x="795" y="310" font-weight="700" fill="#eab308">GPIO21</text> <text x="890" y="310" fill="#475569">→ Motor START [R 4.7kΩ ↓GND]</text>
    <text x="795" y="332" font-weight="700" fill="#eab308">GPIO39</text> <text x="890" y="332" fill="#475569">→ Motor PWM (LEDC CH2, 25kHz)</text>
    <text x="795" y="354" font-weight="700" fill="#eab308">GPIO40</text> <text x="890" y="354" fill="#475569">← Motor FG (PCNT, 6脉冲/转, 3.3V上拉)</text>
  </g>

  <!-- ── RIGHT COLUMN: Sensors ── -->
  <rect x="780" y="386" width="600" height="24" rx="4" fill="#f0fdf4"/>
  <text x="1080" y="403" text-anchor="middle" font-size="12" font-weight="700" fill="#16a34a">传感器 UART + ADC</text>

  <g font-size="11">
    <text x="795" y="436" font-weight="700" fill="#16a34a">GPIO41</text> <text x="890" y="436" fill="#475569">→ Y01 RX (TX→RX 交叉!)</text>
    <text x="795" y="458" font-weight="700" fill="#16a34a">GPIO9</text>  <text x="890" y="458" fill="#475569">← Y01 TX (RX→TX 交叉!)</text>
    <text x="795" y="480" font-weight="700" fill="#16a34a">GPIO8</text>  <text x="890" y="480" fill="#475569">← DS18B20 DQ (4.7kΩ上拉至3.3V)</text>
  </g>

  <!-- ── RIGHT COLUMN: Audio + LED ── -->
  <rect x="780" y="510" width="600" height="24" rx="4" fill="#fdf2f8"/>
  <text x="1080" y="527" text-anchor="middle" font-size="12" font-weight="700" fill="#ec4899">音频 PWM + 状态 LED</text>

  <g font-size="11">
    <text x="795" y="560" font-weight="700" fill="#ec4899">GPIO48</text> <text x="890" y="560" fill="#475569">→ [R 100Ω + C 10nF↓GND] → PAM8302 IN+</text>
    <text x="795" y="582" font-weight="700" fill="#db2777">GPIO38</text> <text x="890" y="582" fill="#475569">→ WS2812 DIN (RGB状态灯, RMT驱动)</text>
  </g>

  <!-- ======================================================================== -->
  <!-- PERIPHERALS — below ESP32 -->
  <!-- ======================================================================== -->

  <!-- ── LCD 4.3" (right side) ── -->
