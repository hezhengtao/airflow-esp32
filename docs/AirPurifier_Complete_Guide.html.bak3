    <div class="gpio lcd"><div class="n lcd">GPIO7</div><div class="f">LCD D3 (bit3)</div><div class="d">8-bit 数据总线</div></div>
    <div class="gpio sensor"><div class="n sensor">GPIO8</div><div class="f">DS18B20 OneWire</div><div class="d">1-Wire · GPIO8 · 输入</div></div>
    <div class="gpio sensor"><div class="n sensor">GPIO9</div><div class="f">Y01 UART RX</div><div class="d">UART1 · 9600bps</div></div>
    <div class="gpio reserved"><div class="n">GPIO10</div><div class="f">保留扩展</div><div class="d">—</div></div>
    <div class="gpio reserved"><div class="n">GPIO11</div><div class="f">保留扩展</div><div class="d">—</div></div>
    <div class="gpio reserved"><div class="n">GPIO12</div><div class="f">保留扩展</div><div class="d">—</div></div>
    <div class="gpio touch"><div class="n touch">GPIO13</div><div class="f">Touch SCL</div><div class="d">I2C1 · 4.7kΩ上拉</div></div>
    <div class="gpio reserved"><div class="n">GPIO14</div><div class="f">保留扩展</div><div class="d">—</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO15</div><div class="f">LCD D4 (bit4)</div><div class="d">8-bit 数据总线</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO16</div><div class="f">LCD D5 (bit5)</div><div class="d">8-bit 数据总线</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO17</div><div class="f">LCD D6 (bit6)</div><div class="d">8-bit 数据总线</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO18</div><div class="f">LCD D7 (bit7)</div><div class="d">8-bit 数据总线</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO19</div><div class="f">LCD BL (背光)</div><div class="d">输出 · PWM 50kHz</div></div>
    <div class="gpio touch"><div class="n touch">GPIO20</div><div class="f">Touch SDA</div><div class="d">I2C1 · 4.7kΩ上拉</div></div>
    <div class="gpio motor"><div class="n motor">GPIO21</div><div class="f">Motor START</div><div class="d">启停 · 4.7kΩ下拉</div></div>
    <div class="gpio reserved"><div class="n">GPIO22-25</div><div class="f">保留扩展</div><div class="d">—</div></div>
