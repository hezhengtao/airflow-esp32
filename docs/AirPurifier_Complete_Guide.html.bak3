    <text x="1060" y="862" fill="#2563eb" font-weight="700">BL</text>     <text x="1250" y="862" fill="#475569">背光 ← GPIO19 (PWM)</text>
    <line x1="1060" y1="880" x2="1340" y2="880" stroke="#e2e8f0" stroke-width="1"/>
    <text x="1060" y="904" fill="#f97316" font-weight="700">Touch SDA</text> <text x="1250" y="904" fill="#f97316">↔ GPIO20</text>
    <text x="1060" y="928" fill="#f97316" font-weight="700">Touch SCL</text> <text x="1250" y="928" fill="#f97316">← GPIO13</text>
    <text x="1060" y="952" fill="#475569" font-weight="700">Touch INT</text>  <text x="1250" y="952" fill="#475569">→ NC (未接)</text>
    <text x="1060" y="976" fill="#475569" font-weight="700">Touch RST</text>  <text x="1250" y="976" fill="#475569">← NC (未接)</text>
