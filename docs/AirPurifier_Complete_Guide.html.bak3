    <div class="gpio motor"><div class="n motor">GPIO39</div><div class="f">Motor PWM/CLK</div><div class="d">LEDC_CH2 · 25kHz</div></div>
    <div class="gpio motor"><div class="n motor">GPIO40</div><div class="f">Motor FG</div><div class="d">PCNT · 转速反馈 · 3.3V上拉</div></div>
    <div class="gpio sensor"><div class="n sensor">GPIO41</div><div class="f">Y01 UART TX</div><div class="d">UART1 · 9600bps</div></div>
    <div class="gpio lcd"><div class="n lcd">GPIO42</div><div class="f">LCD RS (D/C)</div><div class="d">命令/数据选择</div></div>
