<!-- ══════════════════════════════════════════════════ -->
<!-- SIGNAL TRACES — each with unique horizontal Y and vertical X -->
<!-- Horizontal channels: y=553(FG), 567(UART_RX), 581(UART_TX), 595(AUDIO), 609(SHDN) -->
<!-- Right vertical channels: x=545(TX),558(AUD),571(SHDN),584(FG) -->
<!-- Left vertical channels: x=70(DQ),94(UART_RX) -->
<!-- ══════════════════════════════════════════════════ -->

<!-- CLK: GPIO39(530,465) → right→up→LV1(620,380). Simple orthogonal. -->
<g class="nt" data-net="CLK" data-ly="traces">
  <path d="M530 465 L610 465 L610 380 L620 380" stroke="#40c8d8" stroke-width="3.5" fill="none" marker-end="url(#mCLK)"/>
</g>
<g data-net="CLK" data-ly="labels">
  <text x="605" y="460" fill="#40c8d8" font-size="8" font-weight="700" text-anchor="end">GPIO39→LV1</text>
</g>

<!-- CLK5: HV1(770,380) → motor WHT(855,390). Direct right. -->
<g class="nt" data-net="CLK5" data-ly="traces">
  <path d="M770 380 L855 390" stroke="#2098a8" stroke-width="3.5" fill="none" marker-end="url(#mC5)"/>
</g>
<g data-net="CLK5" data-ly="labels">
  <text x="812" y="375" fill="#2098a8" font-size="8" font-weight="700" text-anchor="middle">HV1→WHT</text>
</g>

<!-- FG: Motor YEL(855,420) → R4 → down→left→up→GPIO40(530,490) -->
<!-- Horizontal at y=553, vertical at x=584 (right side) -->
<g class="nt" data-net="FG" data-ly="traces">
  <path d="M855 420 L810 420 L810 553 L584 553 L584 490 L530 490" stroke="#30b898" stroke-width="3.5" stroke-dasharray="7,4" fill="none" marker-end="url(#mFG)"/>
</g>
<!-- R4: FG pull-up at x=810,y=423. Left→3V3 (via x=788 going up) -->
<g data-net="FG" data-ly="comps">
  <rect x="798" y="427" width="24" height="10" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="0.8" rx="1"/>
  <text x="810" y="442" fill="rgba(255,255,255,0.7)" text-anchor="middle" font-size="8">R4 4.7k</text>
  <circle cx="810" cy="425" r="2.5" fill="#c8a050" stroke="#9a7030" stroke-width="0.6"/>
  <circle cx="810" cy="439" r="2.5" fill="#c8a050" stroke="#9a7030" stroke-width="0.6"/>
</g>
<g class="nt" data-net="3V3" data-ly="traces"><path d="M810 439 L788 439 L788 200" stroke="#6090e0" stroke-width="1.8" fill="none"/></g>
<g data-net="FG" data-ly="labels">
  <text x="697" y="547" fill="#30b898" font-size="8" font-weight="700" text-anchor="middle">YEL→GPIO40 (FG) · R4 4.7kΩ</text>
</g>

<!-- DQ: GPIO8(115,390) → down x=70 → right to DS18B20(210,660) -->
<g class="nt" data-net="DQ" data-ly="traces">
  <path d="M70 402 L70 685 L210 685 L210 660" stroke="#b090f0" stroke-width="3.5" stroke-dasharray="7,4" fill="none" marker-end="url(#mDQ)"/>
</g>
<g data-net="DQ" data-ly="labels">
  <text x="140" y="692" fill="#b090f0" font-size="8" font-weight="700" text-anchor="middle">GPIO8→DQ · R3 4.7kΩ</text>
</g>

<!-- UART_RX: GPIO9(115,415) → left to x=94 → down to y=567 → right to Y01 A/TX(635,660) -->
<g class="nt" data-net="UART_RX" data-ly="traces">
  <path d="M115 415 L94 415 L94 567 L635 567 L635 660" stroke="#c080e8" stroke-width="3.5" fill="none" marker-end="url(#mRX)"/>
</g>
<g data-net="UART_RX" data-ly="labels">
  <text x="360" y="561" fill="#c080e8" font-size="8" font-weight="700" text-anchor="middle">Y01 A/TX→GPIO9 (RX)</text>
</g>

<!-- UART_TX: GPIO41(530,315) → right to x=545 → down to y=581 → right to Y01 B/RX(635,690) -->
<g class="nt" data-net="UART_TX" data-ly="traces">
  <path d="M530 315 L545 315 L545 581 L635 581 L635 690" stroke="#e070d0" stroke-width="3.5" fill="none" marker-end="url(#mTX)"/>
</g>
<g data-net="UART_TX" data-ly="labels">
  <text x="590" y="575" fill="#e070d0" font-size="8" font-weight="700" text-anchor="middle">GPIO41→Y01 B/RX (TX)</text>
</g>

<!-- AUDIO: GPIO48(530,415) → right to x=558 → down to y=595 → RC→PAM IN+(295,690) -->
<g class="nt" data-net="AUDIO" data-ly="traces">
  <path d="M530 415 L558 415 L558 595 L370 595 L370 690 L295 690" stroke="#f06070" stroke-width="3.5" fill="none"/>
</g>
<!-- RC filter at (370,595): 100Ω series + 10nF→GND -->
<g data-net="AUDIO" data-ly="comps">
  <rect x="360" y="590" width="20" height="10" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="0.8" rx="1"/>
  <text x="370" y="599" fill="rgba(255,255,255,0.7)" text-anchor="middle" font-size="7">100Ω</text>
  <rect x="386" y="589" width="8" height="10" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="0.7" rx="1"/>
  <text x="390" y="605" fill="rgba(255,255,255,0.5)" text-anchor="middle" font-size="6">10nF</text>
  <line x1="390" y1="601" x2="390" y2="608" stroke="#f06070" stroke-width="0.8"/>
</g>
<g class="nt" data-net="GND" data-ly="traces">
  <line x1="390" y1="610" x2="390" y2="620" stroke="#909090" stroke-width="1"/>
  <path d="M390 620 L430 620 L430 648 L565 648 L565 690" stroke="#909090" stroke-width="1" fill="none"/>
</g>
<g data-net="AUDIO" data-ly="labels">
  <text x="444" y="590" fill="#f06070" font-size="8" font-weight="700" text-anchor="middle">GPIO48→100Ω→10nF→PAM IN+</text>
</g>

<!-- SHDN: GPIO47(530,390) → right to x=571 → down to y=609 → left to PAM SD(295,720) -->
<g class="nt" data-net="SHDN" data-ly="traces">
  <path d="M530 390 L571 390 L571 609 L295 609 L295 720" stroke="#e85088" stroke-width="3.5" fill="none" marker-end="url(#mSH)"/>
</g>
<g data-net="SHDN" data-ly="labels">
  <text x="433" y="603" fill="#e85088" font-size="8" font-weight="700" text-anchor="middle">GPIO47→PAM SD</text>
</g>

<!-- GPIO21 NC marker (at pin position, inside ESP32) -->
<g data-ly="labels">
  <text x="200" y="515" fill="#ef4444" font-size="9" font-weight="700">GPIO21→BRK (悬空不焊)</text>
</g>

