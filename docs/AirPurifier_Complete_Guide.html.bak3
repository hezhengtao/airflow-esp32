    <text x="1060" y="1024" fill="#475569" font-weight="700">GND</text> <text x="1250" y="1024" fill="#475569">共地</text>
  </g>

  <!-- ── Motor (bottom-left) ── -->
  <rect x="80" y="680" width="380" height="260" rx="12" fill="white" stroke="#eab308" stroke-width="2.5" filter="url(#sh2)"/>
