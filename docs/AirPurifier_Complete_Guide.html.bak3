<tr><td>9</td><td>上拉电阻</td><td>4.7kΩ 1/4W 金属膜</td><td>1</td><td>DS18B20 DQ 上拉 (3.3V→R→GPIO8)</td><td>0.5</td></tr>
<tr><td>10</td><td>I2C上拉电阻</td><td>4.7kΩ 1/4W 碳膜</td><td>2</td><td>SDA→3.3V, SCL→3.3V (触摸I2C总线)</td><td>0.5</td></tr>
