  <text x="100" y="892" fill="#a855f7" font-weight="700" font-size="10">⚠ 12V端子并联:</text>
  <rect x="100" y="902" width="330" height="24" rx="4" fill="#faf5ff" stroke="#a855f7" stroke-width="1.5"/>
  <text x="265" y="919" text-anchor="middle" fill="#7c3aed" font-size="10" font-weight="700">C6 470µF/25V 电解 (长脚=+, 短脚=-) + C2 100nF 陶瓷</text>

	  <!-- ── Y01 Air Quality Sensor (mid-bottom) ── -->
	  <rect x="490" y="690" width="240" height="170" rx="12" fill="white" stroke="#16a34a" stroke-width="2.5" filter="url(#sh2)"/>
	  <rect x="490" y="690" width="240" height="32" rx="12" fill="#16a34a"/>
	  <rect x="490" y="710" width="240" height="12" fill="#16a34a"/>
	  <text x="610" y="712" text-anchor="middle" font-size="12" font-weight="700" fill="white">Y01 空气质量传感器</text>
	  <g font-size="10">
	    <text x="505" y="748" fill="#16a34a" font-weight="700">VCC</text>    <text x="600" y="748" fill="#dc2626">+5V ← CH3</text>
	    <text x="505" y="772" fill="#475569" font-weight="700">GND</text>    <text x="600" y="772" fill="#475569">共地</text>
	    <text x="505" y="796" fill="#16a34a" font-weight="700">TX</text>     <text x="600" y="796" fill="#475569">→ ESP32 GPIO9 (RX)</text>
	    <text x="505" y="820" fill="#16a34a" font-weight="700">RX</text>     <text x="600" y="820" fill="#475569">← ESP32 GPIO41 (TX)</text>
	    <text x="505" y="844" fill="#64748b" font-size="9">TVOC+CO2+CH2O · UART 9600bps</text>
	  </g>

	  <!-- ── PAM8302 + Speaker (mid-bottom right) ── -->
	  <rect x="760" y="690" width="250" height="195" rx="12" fill="white" stroke="#ec4899" stroke-width="2.5" filter="url(#sh2)"/>
	  <rect x="760" y="690" width="250" height="32" rx="12" fill="#ec4899"/>
	  <rect x="760" y="710" width="250" height="12" fill="#ec4899"/>
	  <text x="885" y="712" text-anchor="middle" font-size="12" font-weight="700" fill="white">PAM8302 功放 + 8Ω喇叭</text>
	  <g font-size="10">
	    <text x="775" y="748" fill="#ec4899" font-weight="700">VCC</text>    <text x="850" y="748" fill="#dc2626">+5V ← CH3</text>
	    <text x="775" y="772" fill="#475569" font-weight="700">GND</text>    <text x="850" y="772" fill="#475569">共地</text>
	    <text x="775" y="796" fill="#ec4899" font-weight="700">IN+</text>    <text x="850" y="796" fill="#475569">← RC滤波 ← GPIO48</text>
	    <text x="775" y="820" fill="#475569" font-weight="700">IN-</text>    <text x="850" y="820" fill="#475569">→ GND</text>
	    <text x="775" y="844" fill="#ec4899" font-weight="700">SD</text>     <text x="850" y="844" fill="#7c3aed">← 3.3V (使能)</text>
	    <text x="775" y="868" fill="#ec4899" font-weight="700">OUT+</text>   <text x="850" y="868" fill="#475569">→ 喇叭 +</text>
	    <text x="775" y="882" fill="#ec4899" font-weight="700">OUT-</text>   <text x="850" y="882" fill="#475569">→ 喇叭 -</text>
	  </g>

	  <!-- ── DS18B20 Temp Sensor (below Y01) ── -->
	  <rect x="490" y="880" width="240" height="65" rx="8" fill="white" stroke="#0891b2" stroke-width="2" filter="url(#sh)"/>
	  <rect x="490" y="880" width="240" height="24" rx="8" fill="#0891b2"/>
	  <rect x="490" y="896" width="240" height="8" fill="#0891b2"/>
	  <text x="610" y="898" text-anchor="middle" font-size="11" font-weight="700" fill="white">DS18B20 数字温度传感器 (1-Wire)</text>
	  <g font-size="10">
	    <text x="505" y="926" fill="#0891b2" font-weight="700">分压电路</text>
	    <text x="600" y="926" fill="#475569">DQ→GPIO8 (4.7kΩ上拉至3.3V) · VDD→3.3V · GND→GND</text>
	    <text x="505" y="942" fill="#64748b" font-size="9">两线制 · A级 ±0.15°C · CH4 3.3V供电</text>
	  </g>

	  <!-- ── WS2812 Status LED (below PAM8302) ── -->
	  <rect x="760" y="905" width="250" height="55" rx="8" fill="white" stroke="#db2777" stroke-width="2" filter="url(#sh)"/>
	  <rect x="760" y="905" width="250" height="24" rx="8" fill="#db2777"/>
	  <rect x="760" y="921" width="250" height="8" fill="#db2777"/>
	  <text x="885" y="923" text-anchor="middle" font-size="11" font-weight="700" fill="white">WS2812 RGB 状态指示灯</text>
	  <g font-size="10">
	    <text x="775" y="948" fill="#db2777" font-weight="700">DIN</text>  <text x="850" y="948" fill="#475569">← GPIO38 (RMT驱动 · GRB顺序)</text>
	    <text x="775" y="960" fill="#64748b" font-size="9">VCC=5V(CH3) · 优先级: 报警&gt;关机&gt;WiFi故障&gt;WiFi中&gt;正常</text>
	  </g>

	  <!-- ======================================================================== -->
	  <!-- CONNECTION WIRES - Orthogonal PCB-style routing -->
	  <!-- ======================================================================== -->

	  <!-- Y01 UART bus: TX→GPIO9, RX←GPIO41 -->
	  <polyline points="610,796 610,630 890,630 890,458" fill="none" stroke="#16a34a" stroke-width="1.8" marker-end="url(#mb)"/>
	  <polyline points="610,820 610,640 910,640 910,436" fill="none" stroke="#16a34a" stroke-width="1.8" stroke-dasharray="5 3"/>

	  <!-- Motor control: START←GPIO21, PWM←GPIO39, FG→GPIO40 -->
