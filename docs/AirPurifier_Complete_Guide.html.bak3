  <rect x="1040" y="680" width="320" height="32" rx="12" fill="#2563eb"/>
  <rect x="1040" y="700" width="320" height="12" fill="#2563eb"/>
  <text x="1200" y="702" text-anchor="middle" font-size="13" font-weight="700" fill="white">TK043F1509 LCD 4.3" 480×800 IPS</text>
  <g font-size="11">
    <text x="1060" y="742" fill="#2563eb" font-weight="700">D0-D7</text>  <text x="1250" y="742" fill="#475569">8-bit 数据 (GPIO4-7,15-18)</text>
    <text x="1060" y="766" fill="#2563eb" font-weight="700">CS</text>     <text x="1250" y="766" fill="#475569">片选 ← GPIO1</text>
    <text x="1060" y="790" fill="#2563eb" font-weight="700">RS</text>     <text x="1250" y="790" fill="#475569">D/C ← GPIO42</text>
    <text x="1060" y="814" fill="#2563eb" font-weight="700">WR</text>     <text x="1250" y="814" fill="#475569">写使能 ← GPIO2</text>
