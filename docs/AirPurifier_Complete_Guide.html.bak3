<tr><td>5</td><td>温度传感器</td><td>DS18B20 数字温度传感器 1-Wire (±0.5°C)</td><td>1</td><td>温度检测</td><td>12</td><td>立创商城</td></tr>
<tr><td>6</td><td>四路开关电源</td><td>DPC3512 (AC220V→5V/12V/5V/3.3V)</td><td>1</td><td>系统供电</td><td>38</td><td>淘宝</td></tr>
</tbody>
</table>
</div>

