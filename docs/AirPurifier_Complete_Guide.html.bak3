<tr style="background:rgba(234,179,8,.08);"><td>3B</td><td>直流无刷电机 (备选)</td><td>Nidec 42F704S100 (12V, CLK调速, FG反馈, BRK刹车)</td><td>1</td><td>风机升级版</td><td>待定</td><td>淘宝/闲鱼</td></tr>
