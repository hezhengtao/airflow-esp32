  <line x1="280" y1="32" x2="320" y2="32" stroke="#909090" stroke-width="3"/><text x="326" y="36" fill="rgba(255,255,255,0.5)" font-size="9">GND</text>
  <line x1="370" y1="32" x2="410" y2="32" stroke="#40c8d8" stroke-width="2"/><text x="416" y="36" fill="rgba(255,255,255,0.5)" font-size="9">CLK</text>
  <line x1="460" y1="32" x2="500" y2="32" stroke="#30b898" stroke-width="2" stroke-dasharray="7,4"/><text x="506" y="36" fill="rgba(255,255,255,0.5)" font-size="9">FG</text>
  <line x1="8" y1="52" x2="48" y2="52" stroke="#b090f0" stroke-width="2" stroke-dasharray="7,4"/><text x="54" y="56" fill="rgba(255,255,255,0.5)" font-size="9">DQ</text>
  <line x1="100" y1="52" x2="140" y2="52" stroke="#c080e8" stroke-width="2"/><text x="146" y="56" fill="rgba(255,255,255,0.5)" font-size="9">UART_RX</text>
  <line x1="220" y1="52" x2="260" y2="52" stroke="#e070d0" stroke-width="2"/><text x="266" y="56" fill="rgba(255,255,255,0.5)" font-size="9">UART_TX</text>
  <line x1="340" y1="52" x2="380" y2="52" stroke="#f06070" stroke-width="2"/><text x="386" y="56" fill="rgba(255,255,255,0.5)" font-size="9">AUDIO</text>
  <line x1="460" y1="52" x2="500" y2="52" stroke="#e85088" stroke-width="2"/><text x="506" y="56" fill="rgba(255,255,255,0.5)" font-size="9">SHDN</text>
  <rect x="8" y="64" width="16" height="6" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="0.8" rx="1"/><text x="30" y="70" fill="rgba(255,255,255,0.5)" font-size="8">电阻 ▭电容</text>
</g>

</svg>
</div>
<div class="tip" id="pvTip">点击任意彩色导线→高亮整条网络，点击空白处恢复</div>
</div>

<script>
(function(){
var svg=document.getElementById('pvSvg'),wrap=document.getElementById('pvWrap'),tip=document.getElementById('pvTip');
var sc=1,px=0,py=0,dr=0,dx,dy,active=null;
function tr(){svg.style.transform='translate('+px+'px,'+py+'px) scale('+sc+')';}
tr();
wrap.addEventListener('wheel',function(e){e.preventDefault();var r=wrap.getBoundingClientRect(),mx=e.clientX-r.left,my=e.clientY-r.top,old=sc;sc=e.deltaY<0?Math.min(6,sc*1.12):Math.max(0.25,sc/1.12);px=(px-mx)*(sc/old)+mx;py=(py-my)*(sc/old)+my;tr();},{passive:false});
wrap.addEventListener('mousedown',function(e){dr=1;dx=e.clientX-px;dy=e.clientY-py;svg.style.cursor='grabbing';});
window.addEventListener('mousemove',function(e){if(!dr)return;px=e.clientX-dx;py=e.clientY-dy;tr();});
window.addEventListener('mouseup',function(){dr=0;svg.style.cursor='grab';});
svg.addEventListener('click',function(e){var el=e.target;while(el&&el!==svg){var n=el.getAttribute('data-net');if(n){if(active===n){rH();return;}active=n;svg.classList.add('dim');var els=svg.querySelectorAll('[data-net="'+CSS.escape(n)+'"]');for(var i=0;i<els.length;i++)els[i].classList.add('hi');tip.textContent='已高亮: '+n;tip.classList.add('on');return;}el=el.parentNode;}rH();});
window.rH=function(){active=null;svg.classList.remove('dim');var els=svg.querySelectorAll('.hi');for(var i=0;i<els.length;i++)els[i].classList.remove('hi');tip.textContent='点击任意彩色导线→高亮整条网络，点击空白处恢复';tip.classList.remove('on');};
window.tL=function(cb){var ly=cb.getAttribute('data-ly');var els=svg.querySelectorAll('[data-ly="'+CSS.escape(ly)+'"]');for(var i=0;i<els.length;i++)els[i].style.display=cb.checked?'':'none';};
window.z2=function(d){sc=d==='+'?Math.min(6,sc*1.25):Math.max(0.25,sc/1.25);tr();};
window.zr2=function(){sc=1;px=0;py=0;tr();};
})();
</script>

<p style="font-size:12px;color:#94a3b8;margin-top:6px;">
  深绿=FR4基板 · 白框=模块丝印 · 金圆=焊盘 · ▯电阻 ▭电容 · <b>直角正交走线</b> · 点击导线高亮网络
</p>

<h3>12.2 完整接线表 (含导线上所有器件)</h3>

<div style="overflow-x:auto;">
<table style="width:100%;border-collapse:collapse;font-size:13px;">
<thead>
<tr style="background:#0d2818;color:#60d080;">
  <th style="padding:8px;border:1px solid #2d5a3d;text-align:left;">网络</th>
  <th style="padding:8px;border:1px solid #2d5a3d;text-align:left;">颜色</th>
  <th style="padding:8px;border:1px solid #2d5a3d;text-align:left;">导线连接</th>
  <th style="padding:8px;border:1px solid #2d5a3d;text-align:left;">无源器件</th>
  <th style="padding:8px;border:1px solid #2d5a3d;text-align:left;">说明</th>
</tr>
</thead>
<tbody>
<tr><td style="color:#ef7676;font-weight:700;">12V</td><td><span style="display:inline-block;width:14px;height:14px;background:#ef7676;border-radius:3px;"></span></td><td>电源→电机红 · 电源→470µF(+)</td><td>470µF/25V (正→12V, 负→GND)</td><td>电机功率，470µF补偿启动电流</td></tr>
<tr><td style="color:#f0a060;font-weight:700;">5V</td><td><span style="display:inline-block;width:14px;height:14px;background:#f0a060;border-radius:3px;"></span></td><td>电源→电机橙 · 电平HV · Y01 VCC · PAM VCC</td><td>C2(PAM) C3(电平HV) 各100nF→GND</td><td>电机逻辑+外设</td></tr>
<tr><td style="color:#6090e0;font-weight:700;">3V3</td><td><span style="display:inline-block;width:14px;height:14px;background:#6090e0;border-radius:3px;"></span></td><td>电源→ESP32 3V3 · 电平LV · DS18B20 · R1/R2/R3/R4上拉</td><td>C1(电平LV) C4(DS18B20) 各100nF→GND</td><td>主控+传感器+上拉</td></tr>
<tr><td style="color:#909090;font-weight:700;">GND</td><td><span style="display:inline-block;width:14px;height:14px;background:#909090;border-radius:3px;"></span></td><td>全部模块GND互通</td><td>—</td><td>万用表蜂鸣档确认</td></tr>
<tr><td style="color:#40c8d8;font-weight:700;">CLK</td><td><span style="display:inline-block;width:14px;height:14px;background:#40c8d8;border-radius:3px;"></span></td><td>GPIO39→电平LV1</td><td>—</td><td>3.3V→5V电平转换</td></tr>
<tr><td style="color:#2098a8;font-weight:700;">CLK5</td><td><span style="display:inline-block;width:14px;height:14px;background:#2098a8;border-radius:3px;"></span></td><td>电平HV1→电机白</td><td>—</td><td>5V CLK驱动电机</td></tr>
<tr><td style="color:#30b898;font-weight:700;">FG</td><td><span style="display:inline-block;width:14px;height:14px;background:#30b898;border-radius:3px;"></span></td><td>电机黄→GPIO40 · R4→3V3</td><td>R4 4.7kΩ上拉至3V3</td><td>开漏FG必须上拉</td></tr>
<tr><td style="color:#b090f0;font-weight:700;">DQ</td><td><span style="display:inline-block;width:14px;height:14px;background:#b090f0;border-radius:3px;"></span></td><td>GPIO8→DS18B20 DQ · R3→3V3</td><td>R3 4.7kΩ上拉至3V3</td><td>1-Wire必须上拉</td></tr>
<tr><td style="color:#c080e8;font-weight:700;">UART_RX</td><td><span style="display:inline-block;width:14px;height:14px;background:#c080e8;border-radius:3px;"></span></td><td>Y01 A/TX→GPIO9</td><td>—</td><td>交叉连接注意TX→RX</td></tr>
<tr><td style="color:#e070d0;font-weight:700;">UART_TX</td><td><span style="display:inline-block;width:14px;height:14px;background:#e070d0;border-radius:3px;"></span></td><td>GPIO41→Y01 B/RX</td><td>—</td><td>交叉连接注意TX→RX</td></tr>
<tr><td style="color:#f06070;font-weight:700;">AUDIO</td><td><span style="display:inline-block;width:14px;height:14px;background:#f06070;border-radius:3px;"></span></td><td>GPIO48→100Ω→PAM IN+ · 10nF→GND</td><td>100Ω串联 + 10nF对地</td><td>RC低通滤波器 fc≈159kHz</td></tr>
<tr><td style="color:#e85088;font-weight:700;">SHDN</td><td><span style="display:inline-block;width:14px;height:14px;background:#e85088;border-radius:3px;"></span></td><td>GPIO47→PAM SD</td><td>—</td><td>HIGH=工作 LOW=静音</td></tr>
<tr><td style="color:#d0a050;font-weight:700;">SDA</td><td><span style="display:inline-block;width:14px;height:14px;background:#d0a050;border-radius:3px;"></span></td><td>GPIO20→LCD触摸 · R1→3V3</td><td>R1 4.7kΩ上拉至3V3</td><td>I2C必须上拉</td></tr>
<tr><td style="color:#c0a030;font-weight:700;">SCL</td><td><span style="display:inline-block;width:14px;height:14px;background:#c0a030;border-radius:3px;"></span></td><td>GPIO13→LCD触摸 · R2→3V3</td><td>R2 4.7kΩ上拉至3V3</td><td>I2C必须上拉</td></tr>
</tbody>
</table>
</div>

<div style="margin-top:16px;padding:12px;background:#0d2818;border:1px solid #2d5a3d;border-radius:6px;font-size:13px;color:#b8d8c0;">
<strong style="color:#60d080;">无源器件汇总 (共11个)</strong>
<ul style="margin:8px 0 0 20px;columns:2;">
  <li>R1 4.7kΩ — SDA上拉 (GPIO20→3V3)</li>
  <li>R2 4.7kΩ — SCL上拉 (GPIO13→3V3)</li>
  <li>R3 4.7kΩ — DQ上拉 (GPIO8→3V3)</li>
  <li>R4 4.7kΩ — FG上拉 (GPIO40→3V3)</li>
  <li>C1 100nF — 电平LV(3V3)退耦</li>
  <li>C2 100nF — PAM8302(5V)退耦</li>
  <li>C3 100nF — 电平HV(5V)退耦</li>
  <li>C4 100nF — DS18B20(3V3)退耦</li>
  <li>10nF — PAM IN+对GND (RC滤波)</li>
  <li>100Ω — 串联GPIO48→PAM IN+ (RC滤波)</li>
