  <text x="270" y="702" text-anchor="middle" font-size="13" font-weight="700" fill="white">48F704P840 直流无刷电机</text>
  <g font-size="11">
    <circle cx="105" cy="750" r="5" fill="#dc2626"/><text x="120" y="754" fill="#dc2626" font-weight="700">红线: +12V ← CH2</text>
