<h2>二、GPIO 引脚分配总图</h2>

<div class="legend">
  <span class="dot lcd">LCD (GPIO1,2,4-7,15-19,42,46)</span>
  <span class="dot touch">Touch (GPIO20,13)</span>
  <span class="dot motor">Motor (GPIO21,39,40)</span>
  <span class="dot sensor">Sensors (GPIO8,41,9)</span>
  <span class="dot spk">LED+Speaker (GPIO38,48)</span>
</div>

  <div class="gpio-grid">
    <div class="gpio reserved"><div class="n">GPIO0</div><div class="f">Strapping</div><div class="d">启动引脚</div></div>
